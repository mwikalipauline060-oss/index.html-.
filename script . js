/* ── 1. WELCOME POPUP (fires first on load) ── */

window.onload = function () {
  document.getElementById('popup').classList.add('show');
};

function closePopup() {
  document.getElementById('popup').classList.remove('show');
}


/* ── 2. FORM VALIDATION ── */

function submitForm() {
  var name   = document.getElementById('name').value.trim();
  var email  = document.getElementById('email').value.trim();
  var phone  = document.getElementById('phone').value.trim();
  var gender = document.querySelector('input[name="gender"]:checked');

  // Clear old errors
  clearAllErrors();

  var valid = true;

  // Name
  if (!name || name.length < 3) {
    showError('name', 'Please enter your full name (at least 3 characters).');
    valid = false;
  }

  // Email — must match format like Pamikavcollection20@gmail.com
  var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  if (!email) {
    showError('email', 'Please enter your email address.');
    valid = false;
  } else if (!emailRegex.test(email)) {
    showError('email', 'Invalid email. Example: Pamikavcollection20@gmail.com');
    valid = false;
  }

  // Phone — Kenyan format 07xxxxxxxx or +2547xxxxxxxx
  var phoneClean = phone.replace(/\s/g, '');
  var phoneRegex = /^(\+?254|0)7\d{8}$/;
  if (!phone) {
    showError('phone', 'Please enter your phone number.');
    valid = false;
  } else if (!phoneRegex.test(phoneClean)) {
    showError('phone', 'Use format: 0712 345 678 or +254712345678');
    valid = false;
  }

  // Gender
  if (!gender) {
    showGenderError('Please select your gender.');
    valid = false;
  }

  if (!valid) return;

  // All valid → show success popup
  alert('✅ Thank you, ' + name + '!\n\nYour details have been received:\n📧 ' + email + '\n📞 ' + phone + '\n🧑 ' + gender.value + '\n\nWe will contact you soon. Happy shopping! 🛍️');

  // Reset form
  document.getElementById('name').value  = '';
  document.getElementById('email').value = '';
  document.getElementById('phone').value = '';
  if (gender) gender.checked = false;
  clearAllErrors();
}


/* ── 3. ERROR HELPERS ── */

function showError(fieldId, message) {
  var field = document.getElementById(fieldId);
  field.style.borderColor = '#e53935';
  field.style.background  = '#ffebee';

  var err = document.createElement('p');
  err.className = 'error-msg';
  err.id = fieldId + '-err';
  err.textContent = '⚠ ' + message;
  field.parentNode.insertBefore(err, field.nextSibling);
}

function showGenderError(message) {
  var err = document.createElement('p');
  err.className = 'error-msg';
  err.id = 'gender-err';
  err.textContent = '⚠ ' + message;
  var gRow = document.querySelector('.gender-row');
  gRow.parentNode.insertBefore(err, gRow.nextSibling);
}

function clearAllErrors() {
  ['name', 'email', 'phone'].forEach(function(id) {
    var field = document.getElementById(id);
    if (field) {
      field.style.borderColor = '';
      field.style.background  = '';
    }
    var err = document.getElementById(id + '-err');
    if (err) err.remove();
  });
  var gErr = document.getElementById('gender-err');
  if (gErr) gErr.remove();
}
